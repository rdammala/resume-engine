{
  "_comment": "Global engine config. Override per-run with CLI flags.",

  "llm": {
    "provider": "ollama",
    "providers": {
      "ollama": {
        "baseUrl": "http://localhost:11434",
        "model": "llama3",
        "_note": "Free, fully offline. Install from https://ollama.com then: ollama pull llama3"
      },
      "openai": {
        "model": "gpt-4o-mini",
        "apiKeyEnvVar": "OPENAI_API_KEY",
        "_note": "~$0.02-$0.08 per full application. Set OPENAI_API_KEY in your environment."
      },
      "anthropic": {
        "model": "claude-haiku-20240307",
        "apiKeyEnvVar": "ANTHROPIC_API_KEY",
        "_note": "Similar pricing to GPT-4o-mini. Set ANTHROPIC_API_KEY in your environment."
      },
      "gemini": {
        "model": "gemini-1.5-flash",
        "apiKeyEnvVar": "GEMINI_API_KEY",
        "_note": "Has a free tier. Set GEMINI_API_KEY in your environment."
      }
    }
  },

  "resume": {
    "maxPages": 2,
    "fontDocx": "Calibri",
    "fontPdf": "Helvetica",
    "marginInches": 0.5
  },

  "coverLetter": {
    "maxWords": 250,
    "paragraphs": 4
  },

  "portfolio": {
    "stack": "vanilla",
    "googleFont": "Inter",
    "accentColors": [
      { "name": "Blue/Teal",       "a": "#3ac2ff", "b": "#0b5fff" },
      { "name": "Purple/Violet",   "a": "#a78bfa", "b": "#7c3aed" },
      { "name": "Amber/Gold",      "a": "#fbbf24", "b": "#b45309" },
      { "name": "Emerald/Mint",    "a": "#34d399", "b": "#059669" },
      { "name": "Rose/Coral",      "a": "#fb7185", "b": "#be123c" },
      { "name": "Cyan/Electric",   "a": "#22d3ee", "b": "#0e7490" },
      { "name": "Lime/Chartreuse", "a": "#a3e635", "b": "#4d7c0f" },
      { "name": "Indigo/Deep",     "a": "#818cf8", "b": "#3730a3" },
      { "name": "Magenta/Fuchsia", "a": "#f0abfc", "b": "#a21caf" },
      { "name": "Slate/Steel",     "a": "#94a3b8", "b": "#334155" },
      { "name": "Orange/Coral",    "a": "#ff6b3d", "b": "#c2410c" },
      { "name": "Violet/Grape",    "a": "#c084fc", "b": "#6b21a8" }
    ]
  },

  "changelog": {
    "timezone": "PST/PDT",
    "tzid": "America/Los_Angeles"
  }
}
